RAGFLOW_BASE_URL=http://localhost:8080
RAGFLOW_API_KEY=replace-with-a-new-ragflow-api-token
RAGFLOW_DATASET_ID=
RAGFLOW_NOTICE_DATASET_ID=
RAGFLOW_RERANK_ID=

ASSISTANT_HOST=127.0.0.1
ASSISTANT_PORT=8090
SESSION_TTL_HOURS=12

# 本地开发连接 localhost/内网 RAGFlow 时设为 1。
ALLOW_PRIVATE_RAGFLOW=1

# 图片提问使用的 OpenAI 兼容视觉模型。
VLM_BASE_URL=https://api.siliconflow.cn/v1
VLM_API_KEY=replace-with-a-new-vision-api-key
VLM_MODEL=Qwen/Qwen2.5-VL-72B-Instruct

# 可选的 OpenAI 兼容文本模型。未配置时使用规则路由和原文摘要。
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_API_KEY=replace-with-a-new-llm-api-key
LLM_MODEL=Qwen/Qwen2.5-32B-Instruct
