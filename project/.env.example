# RAGFlow 配置模板
# 用法：复制本文件为 .env（cp .env.example .env），填入真值。
# .env 已在 .gitignore，不入库；本文件（.env.example）入库当模板。
#
# API key：浏览器开 http://localhost 登录 RAGFlow 后，头像 → API → 创建
RAGFLOW_API_KEY=

# RAGFlow 服务地址（本地 Docker 容器）
RAGFLOW_BASE_URL=http://localhost

# SiliconFlow VLM（视觉大模型，给 MinerU 抽的图生成 description）
# 申请：https://cloud.siliconflow.cn 注册 → API 密钥 → 新建密钥
SILICONFLOW_API_KEY=
SILICONFLOW_API_BASE=https://api.siliconflow.cn/v1
VISUAL_MODEL=Qwen/Qwen3-VL-8B-Instruct

# 文本模型（跟 VLM 共用同一个 SILICONFLOW_API_KEY）
# 调度 agent：分类任务，7B 够用
TEXT_MODEL=Qwen/Qwen2.5-7B-Instruct
# 分析 agent：生成答案要质量，用 32B
ANALYZER_MODEL=Qwen/Qwen2.5-32B-Instruct

# ── RAGFlow 检索参数（可按需调整）──
# 检索后相关度闸门：max chunk score < 此值且纯检索路径时直接拒答
RETRIEVAL_SCORE_THRESHOLD=0.4
# 返回 chunk 数量
RAGFLOW_TOP_K=6
# 混合检索中向量相似度的权重（0-1，剩余归关键词匹配）
RAGFLOW_VECTOR_SIMILARITY_WEIGHT=0.65
# RAGFlow 服务端相似度阈值（低于此值的 chunk 不会被返回）
RAGFLOW_SIMILARITY_THRESHOLD=0.3
